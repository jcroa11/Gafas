<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Control de Gafas</title>
    <style>
        body { background-color: black; color: #00FF00; font-family: sans-serif; text-align: center; margin: 0; overflow: hidden; }
        #contenedor-video { width: 100%; height: 55vh; background: #111; display: flex; align-items: center; justify-content: center; border-bottom: 2px solid #333; }
        video { width: 100%; height: 100%; object-fit: cover; background: black; }
        .barra-estado { padding: 15px; font-weight: bold; font-size: 16px; background: #000; color: #00FF00; }
        .controles { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; padding: 20px; }
        button { padding: 25px; font-weight: bold; border: none; border-radius: 12px; font-size: 18px; color: black; active { opacity: 0.7; } }
        .btn-foto { background-color: #FFD700; }
        .btn-grabar { background-color: #FF3131; }
        .btn-vol { background-color: #318CE7; color: white; }
        .btn-wa { background-color: #25D366; grid-column: span 2; color: white; }
    </style>
</head>
<body>

    <div id="contenedor-video">
        <video id="camara" autoplay playsinline muted></video>
    </div>

    <div class="barra-estado" id="estado">ESTADO: INICIANDO...</div>

    <div class="controles">
        <button class="btn-foto" onclick="capturarFoto()">📸 FOTO</button>
        <button class="btn-grabar" id="btnRec" onclick="controlarGrabacion()">🎥 GRABAR</button>
        <button class="btn-vol" onclick="ajustarVolumen(0.1)">VOL +</button>
        <button class="btn-vol" onclick="ajustarVolumen(-0.1)">VOL -</button>
        <button class="btn-wa" onclick="mandarWhatsApp()">📤 ENVIAR REPORTE WA</button>
    </div>

    <script>
        const video = document.getElementById('camara');
        const estado = document.getElementById('estado');
        let recorder;
        let clips = [];

        // ARRANCAR CÁMARA TRASERA
        async function activarCamara() {
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ 
                    video: { facingMode: "environment" }, 
                    audio: true 
                });
                video.srcObject = stream;
                estado.innerText = "ESTADO: HARDWARE CONECTADO";
            } catch (err) {
                estado.innerText = "ERROR: ACCESO DENEGADO";
                estado.style.color = "red";
            }
        }

        function capturarFoto() {
            const canvas = document.createElement('canvas');
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            canvas.getContext('2d').drawImage(video, 0, 0);
            const data = canvas.toDataURL('image/jpeg');
            const link = document.createElement('a');
            link.href = data;
            link.download = `inspeccion_${Date.now()}.jpg`;
            link.click();
            estado.innerText = "ESTADO: FOTO CAPTURADA";
        }

        function controlarGrabacion() {
            const btn = document.getElementById('btnRec');
            if (!recorder || recorder.state === "inactive") {
                clips = [];
                recorder = new MediaRecorder(video.srcObject);
                recorder.ondataavailable = e => clips.push(e.data);
                recorder.onstop = () => {
                    const blob = new Blob(clips, { type: 'video/mp4' });
                    const url = URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = `video_${Date.now()}.mp4`;
                    a.click();
                };
                recorder.start();
                btn.innerText = "🛑 PARAR";
                estado.innerText = "ESTADO: GRABANDO...";
            } else {
                recorder.stop();
                btn.innerText = "🎥 GRABAR";
                estado.innerText = "ESTADO: VIDEO GUARDADO";
            }
        }

        function ajustarVolumen(v) {
            // Sincronización visual del volumen
            estado.innerText = "VOLUMEN AJUSTADO";
            setTimeout(() => { estado.innerText = "ESTADO: HARDWARE CONECTADO"; }, 1000);
        }

        function mandarWhatsApp() {
            window.open('https://wa.me/?text=Reporte%20de%20inspección%20terminado', '_blank');
        }

        window.onload = activarCamara;
    </script>
</body>
</html>
