<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gafas Inteligentes - Control Técnico</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #000;
            color: white;
            font-family: Arial, sans-serif;
            display: flex;
            flex-direction: column;
            height: 100vh;
            overflow: hidden;
        }

        #video-container {
            position: relative;
            flex: 1;
            background: #1a1a1a;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            cursor: pointer;
        }

        .status-bar {
            background: #000;
            color: #00ff00;
            text-align: center;
            padding: 10px;
            font-weight: bold;
            font-size: 14px;
            letter-spacing: 1px;
        }

        .controls-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            padding: 15px;
            background: #111;
        }

        button {
            border: none;
            padding: 20px;
            font-size: 16px;
            font-weight: bold;
            border-radius: 10px;
            color: white;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        #btnFoto { background-color: #ffcc00; color: #000; }
        #btnGrabar { background-color: #ff3b30; }
        #btnVolMas, #btnVolMenos { background-color: #2b78ff; }
        #btnWhatsApp { 
            grid-column: span 2; 
            background-color: #25d366; 
            padding: 25px;
        }

        button:active { opacity: 0.7; transform: scale(0.98); }
    </style>
</head>
<body>

    <div class="status-bar" id="estado">ESTADO: GAFAS ACTIVAS - SAMSUNG A34</div>

    <div id="video-container">
        <video id="video" autoplay playsinline></video>
    </div>

    <div class="controls-container" id="controles">
        <button id="btnFoto">📸 FOTO</button>
        <button id="btnGrabar">🎥 GRABAR</button>
        <button id="btnVolMas">VOL +</button>
        <button id="btnVolMenos">VOL -</button>
        <button id="btnWhatsApp">📲 ENVIAR REPORTE / TRANSMITIR WA</button>
    </div>

    <script>
        // --- CONFIGURACIÓN BLUETOOTH (DATOS DE TU LOG/nRF) ---
        const SERVICE_UUID = 0x1801; 
        const CHARACTERISTIC_UUID = 0x2A06; // Característica con permiso de WRITE
        let gafaChar;

        // --- INICIAR CÁMARA DEL CELULAR (VISOR) ---
        async function iniciarCamara() {
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: "environment" } });
                document.getElementById('video').srcObject = stream;
            } catch (err) {
                console.error("Error cámara:", err);
                document.getElementById('estado').innerText = "ERROR: CÁMARA NO DISPONIBLE";
            }
        }

        // --- CONECTAR GAFAS ---
        async function conectarGafas() {
            try {
                const device = await navigator.bluetooth.requestDevice({
                    filters: [{ name: 'XKOENPRO_282B' }],
                    optionalServices: [SERVICE_UUID]
                });
                const server = await device.gatt.connect();
                const service = await server.getPrimaryService(SERVICE_UUID);
                gafaChar = await service.getCharacteristic(CHARACTERISTIC_UUID);
                document.getElementById('estado').innerText = "ESTADO: GAFAS VINCULADAS";
            } catch (err) {
                console.log("Error BT:", err);
            }
        }

        // --- ENVIAR COMANDOS ---
        async function enviarComando(cmd) {
            if (gafaChar) {
                const encoder = new TextEncoder();
                await gafaChar.writeValue(encoder.encode(cmd));
            } else {
                console.log("Gafas no conectadas. Comando ignorado: " + cmd);
            }
        }

        // --- PANTALLA COMPLETA ---
        function toggleFullscreen() {
            const elem = document.getElementById('video');
            if (!document.fullscreenElement) {
                elem.requestFullscreen().catch(err => console.log(err));
            } else {
                document.exitFullscreen();
            }
        }

        // --- VINCULACIÓN DE BOTONES ---
        document.getElementById('btnFoto').onclick = () => {
            // Lógica para capturar foto (Canvas) y enviar comando
            enviarComando('SNAP');
            alert("Foto capturada");
        };

        document.getElementById('btnGrabar').onclick = () => enviarComando('REC');
        document.getElementById('btnVolMas').onclick = () => enviarComando('V+');
        document.getElementById('btnVolMenos').onclick = () => enviarComando('V-');

        document.getElementById('btnWhatsApp').onclick = () => {
            // Activar pantalla completa para transmisión limpia
            toggleFullscreen();
            
            // Abrir WhatsApp después de un breve delay
            setTimeout(() => {
                const msg = encodeURIComponent("Iniciando transmisión técnica. Por favor, mira mi pantalla.");
                window.open(`https://wa.me/573XXXXXXXXX?text=${msg}`, '_blank');
            }, 1500);
        };

        // Doble toque en el video para pantalla completa manual
        document.getElementById('video').onclick = toggleFullscreen;

        // Auto-inicio
        iniciarCamara();
        // Llamar a conectarGafas() mediante un gesto del usuario (requerido por Chrome)
        document.body.addEventListener('click', () => {
            if(!gafaChar) conectarGafas();
        }, {once: true});

    </script>
</body>
</html>

